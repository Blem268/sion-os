{
  "name": "sion-os",
  "version": "2.2.0",
  "description": "Sion Life OS — terminal-aesthetic personal operating system",
  "author": "Sion Looby-Martinez <sion@antiguaos.ag>",
  "main": "electron/main.js",
  "scripts": {
    "start":   "electron .",
    "dev":     "electron . --dev",
    "pack":    "electron-builder --mac --dir",
    "build":   "electron-builder --mac --config.mac.identity=null"
  },
  "build": {
    "appId":        "ag.antigua.sionos",
    "productName":  "Sion OS",
    "copyright":    "© 2026 Sion Looby-Martinez",
    "asar":         true,
    "mac": {
      "category":          "public.app-category.productivity",
      "icon":              "electron/assets/icon.iconset/icon_512x512@2x.png",
      "darkModeSupport":   true,
      "hardenedRuntime":   false,
      "gatekeeperAssess":  false,
      "identity":          null,
      "target": [
        { "target": "dir", "arch": ["arm64"] }
      ]
    },
    "directories": {
      "output":    "dist",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "style.css",
      "app.js",
      "data/**/*",
      "modules/**/*",
      "!electron/assets/icon.iconset"
    ],
    "extraResources": [],
    "npmRebuild": false
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {}
}
